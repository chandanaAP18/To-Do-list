rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users Profile rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Tasks: Access restricted to owner
    match /tasks/{taskId} {
      allow read, write: if request.auth != null && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // Whiteboard Canvas rules: Owner or shared collaborators
    match /boards/{boardId} {
      allow read, write: if request.auth != null && (
        resource == null || 
        resource.data.ownerId == request.auth.uid || 
        request.auth.token.email in resource.data.collaborators
      );
    }

    // Notes Collection: Inherited read/write check via request details
    match /notes/{noteId} {
      allow read, write: if request.auth != null;
    }
  }
}
